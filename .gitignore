# Python 环境
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.dll

# 模型权重文件 (全路径封杀)
**/*.pth
**/*.h5

# 预处理生成的数据 (全路径封杀，但保留关键的小文件)
**/*.npy
**/*.npz
# 例外：processed_tri_data 里的预处理结果（共约 2MB，Colab 必须）
!processed_tri_data/data.npy
!processed_tri_data/label.npy

# 大型数据文件 (全路径封杀)
**/*.xlsx
**/*.xls
**/*.csv
# 如果你想保留某些小的 csv (比如 smiles.csv)，可以在下面排除
!**/smiles.csv

# Jupyter & 图片
.ipynb_checkpoints/
figure/
*.png
*.jpg
*.jpeg

# 系统文件
.DS_Store
Thumbs.db
